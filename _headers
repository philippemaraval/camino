# GeoJSON data files: cache 1 hour, revalidate after
/data/*
  Cache-Control: public, max-age=3600, must-revalidate

# CSS: cache 10 minutes, revalidate
/*.css
  Cache-Control: public, max-age=600, must-revalidate

# JS: NO cache — always fetch fresh version
/*.js
  Cache-Control: no-cache, must-revalidate

# HTML: NO cache
/*.html
  Cache-Control: no-cache, must-revalidate
/
  Cache-Control: no-cache, must-revalidate
