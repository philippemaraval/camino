const CACHE_NAME="camino-v3",PRECACHE_URLS=["/","/index.html","/style.css","/main.js","/data_rules.js","/site.webmanifest","https://unpkg.com/leaflet@1.9.4/dist/leaflet.css","https://unpkg.com/leaflet@1.9.4/dist/leaflet.js","https://cdn.jsdelivr.net/npm/leaflet-minimap@3.6.1/dist/Control.MiniMap.min.css","https://cdn.jsdelivr.net/npm/leaflet-minimap@3.6.1/dist/Control.MiniMap.min.js","https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"],CDN_HOSTS=new Set(["unpkg.com","cdn.jsdelivr.net"]);self.addEventListener("install",e=>{e.waitUntil(caches.open(CACHE_NAME).then(n=>n.addAll(PRECACHE_URLS)).then(()=>self.skipWaiting()))}),self.addEventListener("activate",e=>{e.waitUntil(caches.keys().then(n=>Promise.all(n.filter(t=>t.startsWith("camino-")&&t!==CACHE_NAME).map(t=>caches.delete(t)))).then(()=>self.clients.claim()))});async function networkFirst(e,n){try{const t=await fetch(e);return t&&t.ok&&(await caches.open(CACHE_NAME)).put(e,t.clone()),t}catch(t){const s=await caches.match(e);if(s)return s;if(n){const a=await caches.match(n);if(a)return a}throw t}}async function cacheFirst(e){const n=await caches.match(e);if(n)return n;const t=await fetch(e);return t&&t.ok&&(await caches.open(CACHE_NAME)).put(e,t.clone()),t}self.addEventListener("fetch",e=>{const{request:n}=e;if(n.method!=="GET")return;const t=new URL(n.url);if(t.pathname.startsWith("/api/"))return;const s=n.mode==="navigate",a=t.origin===self.location.origin,i=a&&t.pathname.startsWith("/data/"),c=a&&(t.pathname.endsWith(".js")||t.pathname.endsWith(".css")||t.pathname.endsWith(".html")||t.pathname==="/"||t.pathname.endsWith(".webmanifest")),h=CDN_HOSTS.has(t.hostname);if(s){e.respondWith(networkFirst(n,"/index.html"));return}if(i||c){e.respondWith(networkFirst(n));return}h&&e.respondWith(cacheFirst(n))});
