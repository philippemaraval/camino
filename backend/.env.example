PORT=3000
NODE_ENV=development

# Required in production: JWT signing secret
SECRET_KEY=change-me-to-a-long-random-string

# Frontend origin allow-list
FRONTEND_URL=https://your-frontend.example
# Optional: comma-separated list of additional origins
CORS_ALLOWED_ORIGINS=https://preview-one.example,https://preview-two.example

# Optional admin maintenance routes (disabled by default)
ENABLE_ADMIN_ROUTES=false
ADMIN_API_KEY=change-me-admin-key
